            }
        },
        {
            "src": "api/tickets/use.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "core/**",
                    "pos-service/**",
                    "smaq-service/**",
                    "google-sheets-service/**",
                    "mercadopago-service/**",
                    "reservations-service/**",
