                ]
            }
        },
        {
            "src": "api/webhook/dracma.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "core/**",
                    "pos-service/**",
                    "smaq-service/**",
                    "google-sheets-service/**",
                    "mercadopago-service/**",
                    "reservations-service/**",
                    "qr-service/**",
                    "auth-service/**"
                ]
            }
        },
        {
            "src": "api/webhook/mercadopago.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "core/**",
                    "pos-service/**",
                    "smaq-service/**",
                    "google-sheets-service/**",
                    "mercadopago-service/**",
                    "reservations-service/**",
                    "qr-service/**",
                    "auth-service/**"
                ]
            }
        },
        {
            "src": "nfc-pos/**",
            "use": "@vercel/static"
        },
        {
            "src": "staff-app-v2/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/pos/(.*)",
            "dest": "/api/pos.ts?route=$1"
        },
        {
            "src": "/api/pos",
            "dest": "/api/pos.ts"
        },
        {
            "src": "/api/smaq/(.*)",
            "dest": "/api/smaq/$1.ts"
        },
        {
            "src": "/api/(checkout)",
            "dest": "/api/$1.ts"
        },
        {
            "src": "/api/webhook/(.*)",
            "dest": "/api/webhook/$1.ts"
        },
        {
            "src": "/api/tickets/(.*)",
            "dest": "/api/tickets/$1.ts"
        },
        {
            "src": "/nfc-pos/(.*)",
            "dest": "/nfc-pos/$1"
        },
        {
            "src": "/nfc-pos",
            "dest": "/nfc-pos/index.html"
        },
        {
            "src": "/staff-app-v2/(.*)",
            "dest": "/staff-app-v2/$1"
        },
        {
            "src": "/staff-app-v2",
            "dest": "/staff-app-v2/index.html"
        },
        {
            "src": "/staff",
            "dest": "/staff-app-v2/index.html"
        }
    ]
}
